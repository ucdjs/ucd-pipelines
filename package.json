{
  "name": "@ucdjs/data-pipelines",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/ucdjs/ucd-pipelines",
  "bugs": {
    "url": "https://github.com/ucdjs/ucd-pipelines/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Lucas Nørgaard",
    "email": "lucasnrgaard@gmail.com",
    "url": "https://luxass.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ucdjs/ucd-pipelines.git"
  },
  "type": "module",
  "imports": {
    "#sources/*": "./sources/*.source.ts",
    "#routes/*": "./routes/*.route.ts"
  },
  "scripts": {
    "pipelines:list": "ucd pipelines list --cwd .",
    "pipelines:run": "ucd pipelines run --cwd .",
    "pipelines:run:ui": "ucd pipelines run --cwd . --ui",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@ucdjs/pipelines-core": "catalog:pipelines"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "@ucdjs/cli": "catalog:pipelines",
    "oxfmt": "catalog:dev",
    "oxlint": "catalog:dev",
    "oxlint-tsgolint": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "engines": {
    "node": ">=24.13"
  },
  "packageManager": "pnpm@10.29.3"
}
